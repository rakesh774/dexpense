<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base: Pristine White with a hint of warmth -->
    <path
        android:fillColor="#FCFCFC"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Soft Liquid Bloom 1 (Top Left) -->
    <path
        android:pathData="M-10,-10 C40,40 100,-20 120,-10 L-10,-10 Z"
        android:fillAlpha="0.3">
        <gradient
            android:startX="0"
            android:startY="0"
            android:endX="60"
            android:endY="60"
            android:type="linear">
            <item android:offset="0" android:color="#E0F2F1" /> <!-- Soft Mint/Teal -->
            <item android:offset="1" android:color="#00E0F2F1" />
        </gradient>
    </path>

    <!-- Soft Liquid Bloom 2 (Bottom Right) -->
    <path
        android:pathData="M118,118 C78,78 18,128 -10,118 L118,118 Z"
        android:fillAlpha="0.4">
        <gradient
            android:startX="108"
            android:startY="108"
            android:endX="48"
            android:endY="48"
            android:type="linear">
            <item android:offset="0" android:color="#E3F2FD" /> <!-- Soft Blue -->
            <item android:offset="1" android:color="#00E3F2FD" />
        </gradient>
    </path>

    <!-- Glass Specular Highlight (Inner Glow) -->
    <path
        android:pathData="M24,24 Q54,18 84,24 Q90,54 84,84 Q54,90 24,84 Q18,54 24,24 Z"
        android:fillAlpha="0.05"
        android:fillColor="#007AFF" />

    <!-- Subtle Refractive Line -->
    <path
        android:pathData="M10,20 Q54,5 98,20"
        android:strokeWidth="1.5"
        android:strokeColor="#1AFFFFFF"
        android:strokeLineCap="round" />

</vector>
