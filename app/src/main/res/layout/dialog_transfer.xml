<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/white_card_bg"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_margin="20dp"
    android:minWidth="350dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transfer Money"
        android:textColor="#1C1C1E"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Move funds between Air and Solid accounts"
        android:textColor="#8E8E93"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etTransferAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/liquid_glass_card"
        android:hint="Amount"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:textColor="#1C1C1E"
        android:textColorHint="#8E8E93" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="From"
        android:textColor="#1C1C1E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rgTransferFrom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbFromAir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Air Cash"
            android:textColor="#1C1C1E"
            android:buttonTint="#AF52DE"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbFromSolid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Solid Cash"
            android:textColor="#1C1C1E"
            android:buttonTint="#AF52DE" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="To"
        android:textColor="#1C1C1E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTransferTo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/liquid_glass_card"
        android:padding="16dp"
        android:text="Solid Cash"
        android:textColor="#1C1C1E" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirmTransfer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/liquid_glass_button"
        android:text="Confirm Transfer"
        android:textAllCaps="false"
        android:textColor="#AF52DE"
        android:textStyle="bold"
        android:textSize="18sp" />

</LinearLayout>
